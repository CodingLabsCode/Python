from random import choice , shuffle
from time import sleep
from string import ascii_letters , digits 

def gen():
    chars = ascii_letters + digits
    other_chars = ("!@£$%^&*()§:;=+-_|/?<>")
    password = ""
    
    length = int(input("\nHow long would you like your password to be:\n"))
    length -= 2

    print("\nMaking Password\n");sleep(1)

    for x in range(length):password += choice(chars)
    for x in range(2):password += choice(other_chars)

    password_list = list(password)
    shuffle (password_list)
    password = "".join(password_list)

    print(f"Your new password is {password}\n")

gen()
sleep(0.2)
print("loading..\n")
sleep(0.5)
user_input = input("Would you like to make another password (yes)/(no):\n")

if user_input == "yes":
    print("\nLoading...")
    sleep(0.5)
    gen()
else:
    print("Goodbye")
